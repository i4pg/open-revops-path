# ---- Secrets / credentials (PDPL: never commit) ----
.env
.env.*
*.pem
*.key
credentials.json
service-account*.json

# ---- Real / raw data (keep anonymized samples out of git) ----
data/raw/
data/private/
data/*.csv
data/*.tsv
data/*.parquet
data/*.xlsx
data/*.xls
data/*.json
data/*.db
data/*.sqlite
